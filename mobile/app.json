{
  "expo": {
    "name": "TaskManager",
    "slug": "taskmanager",
    "scheme": "taskmanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taskmanager.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      },
      "package": "com.taskmanager.app"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ]
  }
}
